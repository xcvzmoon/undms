# Auto detect text files and perform LF normalization
*        text=auto

# Binary files - must be marked to prevent line ending corruption on Windows
*.pdf    binary
*.docx   binary
*.xlsx   binary
*.xls    binary
*.pptx   binary
*.ppt    binary
*.jpg    binary
*.jpeg   binary
*.png    binary
*.gif    binary
*.bmp    binary
*.ico    binary
*.zip    binary
*.gz     binary
*.tar    binary
*.node   binary


*.ts    text eol=lf merge=union
*.tsx   text eol=lf merge=union
*.rs    text eol=lf merge=union
*.js    text eol=lf merge=union
*.json  text eol=lf merge=union
*.debug text eol=lf merge=union

# Generated codes
index.js                         linguist-detectable=false
index.d.ts                       linguist-detectable=false
undms.wasi-browser.js linguist-detectable=false
undms.wasi.cjs        linguist-detectable=false
wasi-worker-browser.mjs          linguist-detectable=false
wasi-worker.mjs                  linguist-detectable=false
