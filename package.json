{
  "name": "undms",
  "version": "1.4.0",
  "description": "Text and Metadata Extraction Library for Document Files with Text Similarity Comparison",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xcvzmoon/undms.git"
  },
  "author": {
    "name": "Mon Albert Gamil",
    "email": "mrgamilmonalbert@gmail.com",
    "url": "https://github.com/xcvzmoon/"
  },
  "license": "MIT",
  "browser": "browser.js",
  "keywords": [
    "document",
    "pdf",
    "word",
    "docs",
    "excel",
    "text-extraction",
    "metadata-extraction",
    "text-similarity-comparision"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "index.mjs",
    "browser.js"
  ],
  "napi": {
    "binaryName": "undms",
    "packageName": "@xcvzmoon/undms",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "optionalDependencies": {
    "@xcvzmoon/undms-darwin-arm64": "1.4.0",
    "@xcvzmoon/undms-darwin-x64": "1.4.0",
    "@xcvzmoon/undms-linux-arm64-gnu": "1.4.0",
    "@xcvzmoon/undms-linux-x64-gnu": "1.4.0",
    "@xcvzmoon/undms-linux-x64-musl": "1.4.0",
    "@xcvzmoon/undms-win32-x64-msvc": "1.4.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "bench:text": "node --import @oxc-node/core/register benchmark/bench-text.ts",
    "bench:similarity": "node --import @oxc-node/core/register benchmark/bench-similarity.ts",
    "bench:documents": "node --import @oxc-node/core/register benchmark/bench-documents.ts",
    "bench:image": "node --import @oxc-node/core/register benchmark/bench-image.ts",
    "build": "pnpm run build:cjs && pnpm run build:esm",
    "build:cjs": "napi build --platform --release --js index.js",
    "build:esm": "napi build --platform --release --esm --js index.mjs",
    "build:debug": "napi build --platform",
    "docs": "vitepress dev docs --port 3000",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 4173",
    "format": "run-p format:oxfmt format:rs format:toml",
    "format:oxfmt": "oxfmt && oxfmt --check",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "oxlint --type-aware",
    "prepublishOnly": "echo 'Publishing split packages via CI workflow'",
    "test": "pnpm run build && ava",
    "test:bindings": "ava",
    "preversion": "pnpm run build:cjs && pnpm run build:esm && git add .",
    "version": "napi version",
    "prepare": "husky",
    "changelog": "changelogen",
    "changelog:bump": "changelogen --bump",
    "changelog:release": "changelogen --release"
  },
  "devDependencies": {
    "@emnapi/core": "^1.8.1",
    "@emnapi/runtime": "^1.8.1",
    "@napi-rs/cli": "^3.5.1",
    "@oxc-node/core": "^0.0.35",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.1",
    "@types/node": "^25.3.0",
    "ava": "^6.4.1",
    "chalk": "^5.6.2",
    "changelogen": "^0.6.2",
    "consola": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.12.2",
    "tinybench": "^6.0.0",
    "typescript": "^5.9.3",
    "vitepress": "2.0.0-alpha.16"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "oxlint --fix"
    ],
    "*.{js,ts,json,jsonc,md,yml,yaml}": [
      "oxfmt ."
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "packageManager": "pnpm@10.30.1"
}
